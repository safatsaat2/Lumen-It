# ------------------------------------------------------------------
# Mihi's Agency — environment variables
# Requires Node.js >= 22 (see package.json engines).
# Copy to .env.local and fill in real values. Never commit real secrets.
# ------------------------------------------------------------------

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://example.com

# Resend API key — https://resend.com
RESEND_API_KEY=

# Recipient for contact form submissions
CONTACT_TO_EMAIL=you@example.com

# Verified sender address in Resend (use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=Website <onboarding@resend.dev>

# Admin login — REQUIRED (also for local dev). There are no built-in defaults;
# the admin area fails closed if any of these is missing.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Long random string, e.g. `openssl rand -base64 32`
ADMIN_SESSION_SECRET=

# ------------------------------------------------------------------
# AI consultation (Groq via AI SDK)
# ------------------------------------------------------------------

# GroqCloud API key — https://console.groq.com
# Optional if an admin-configured key is saved (see AI_SETTINGS_ENCRYPTION_KEY).
GROQ_API_KEY=

# Required to save/read an API key from the admin panel. Must decode to
# exactly 32 bytes; use base64 (`openssl rand -base64 32`) or 64 hex
# characters (`openssl rand -hex 32`). Without it, only GROQ_API_KEY works.
AI_SETTINGS_ENCRYPTION_KEY=

# ------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------

# Vercel Blob — REQUIRED on Vercel for site content, consultations, and the
# encrypted key store. Create a Blob store in Vercel → Storage → Blob.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Optional: GitHub Contents API fallback for SITE CONTENT ONLY (never used
# for consultation data).
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
